# ─── ALPACA MARKETS ────────────────────────────────────────────────────────────
# Obtén tus claves en: https://app.alpaca.markets/paper-overview (paper)
# o https://app.alpaca.markets/brokerage/dashboard/overview (live)

ALPACA_KEY_ID=TU_KEY_ID_AQUI
ALPACA_SECRET_KEY=TU_SECRET_KEY_AQUI

# true = paper trading (simulado, sin dinero real) | false = live (dinero real)
ALPACA_PAPER=true

# Símbolos a operar — cripto usa formato "BTC/USD", acciones usan "AAPL"
ALPACA_SYMBOLS=BTC/USD,ETH/USD

# ─── CONTROL DE ÓRDENES ────────────────────────────────────────────────────────
# Mínimo en USD por orden enviada a Alpaca (Alpaca requiere mínimo ~$1)
ALPACA_MIN_NOTIONAL=10

# Máximo en USD por orden — protege de órdenes demasiado grandes
ALPACA_MAX_NOTIONAL=500

# ─── EVOLUCIÓN ─────────────────────────────────────────────────────────────────
# Número de agentes iniciales
EVO_AGENTS=20

# Milisegundos entre ticks del motor de evolución
EVO_TICK_MS=2000

# true = usar precio de Alpaca WS | false = usar Binance (solo BTC sim)
EVO_USE_ALPACA_PRICE=true
